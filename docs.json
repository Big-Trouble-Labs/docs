{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PitchWeave",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#2563EB"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Legal",
        "groups": [
          {
            "group": "Policies",
            "pages": [
              "legal/terms-of-service",
              "legal/privacy-policy",
              "legal/cookie-policy"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "PitchWeave App",
          "href": "https://build.pitchweave.app",
          "icon": "presentation-screen"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "mailto:legal@pitchweave.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://build.pitchweave.app"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/pitchweave"
    }
  }
}
